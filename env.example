# --- Supabase (from your project's API settings) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_OR_PUBLISHABLE_KEY
# Server-only (never exposed to the browser) — used by ingest/precompute jobs:
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_OR_SECRET_KEY

# --- LLM provider ---
# Single-provider default keeps the build simple (one key). Swap any of these
# without code changes; the router reads them.
ANTHROPIC_API_KEY=YOUR_KEY
CHEAP_MODEL=claude-haiku-4-5
CAPABLE_MODEL=claude-sonnet-4-6
VISION_MODEL=claude-sonnet-4-6
# Optional: cheaper cheap-path via a second provider (Gemini 3.1 Flash-Lite).
# GOOGLE_GENERATIVE_AI_API_KEY=YOUR_KEY
# CHEAP_MODEL=gemini-3.1-flash-lite
